[Unit]
Description=Sieger CV API (FastAPI / uvicorn)
After=network.target sieger-inspection.service
Requires=sieger-inspection.service

[Service]
Type=simple
User={{DEPLOY_USER}}
Group={{DEPLOY_GROUP}}
WorkingDirectory={{WORKDIR}}
Environment=PYTHONPATH={{WORKDIR}}
ExecStart={{VENV_PYTHON}} -m uvicorn src.api.main:app \
    --host 0.0.0.0 \
    --port 5002 \
    --workers 1 \
    --log-level info \
    --no-access-log
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sieger-api

# Prevent runaway
MemoryMax=2G
CPUQuota=50%

[Install]
WantedBy=multi-user.target
